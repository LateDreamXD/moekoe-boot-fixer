{
  "$schema": "node_modules/@latedream/moekoe-plugin-utils/schema/lkp_utils.json",
  "manifest": {
    "outpath": "dist/manifest.json"
  },
  "meta": {
    "permissions": ["scripting"],
    "injects": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.iife.js"],
        "run_at": "document_end"
      }
    ],
    "icons": {
      "256": "icon.png"
    },
    "generator": "moekoe-plugin-template-ts"
  }
}
